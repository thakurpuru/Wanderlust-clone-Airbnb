<% layout("./layouts/boilerplate") %>

<div class="main-container"></div>    
<div class="container my-4">

  <div class="row g-4">

    <!-- LEFT: LISTING -->
    <div class="col-12 col-lg-7">
      <div class="listing-card p-3">

        <h4 class="mb-2"><%= listing.title %></h4>

        <div class="image-container">
          <img src="<%= listing.image.url %>" >
        </div>

        <p><%= listing.description %></p>

        <p class="price fw-bold">
          ₹<%= listing.price.toLocaleString("en-IN") %>/night
        </p>

        <p class="text-muted mb-1"><%= listing.location %></p>
        <p class="text-muted"><%= listing.country %></p>

        <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
        <div class="action-buttons">
            <form action="/listings/<%= listing._id %>/edit">
                <button type="submit" class="btn-edit">Edit</button>
            </form>

            <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
                <button type="submit" class="btn-delete">Delete</button>
            </form>
        </div>
        <% } %>

      </div>
    </div>


    <!-- RIGHT: REVIEWS -->
    <div class="col-12 col-lg-5">

      <!-- Review Form -->
      <% if(currUser){ %>
      <div class="review-form-card mb-4">
        <h5>Leave a Review</h5>

        <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

         <div class="form-group">
                    <fieldset class="starability-checkmark">
                        <legend><h5>Rating</h5></legend>
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                     </fieldset>
                </div>
                <div class="form-group">
                    <label for="comment" class="form-lable"><h5>Comment</h5></label>
                    <textarea name="review[comment]" class="form-control" id="comment" required></textarea>
                    <div class="invalid-feedback">
                        Please add comment for review.
                    </div>
                </div>
          <button class="review-btn" type="submit">
            Submit Review
          </button>
        </form>
      </div>
      <% } %>


      <!-- All Reviews -->
      <h5 class="mb-3">All Reviews</h5>

      <% for(let review of listing.reviews){ %>
      <div class="review-card mb-3">

        <div class="d-flex justify-content-between">
          <strong>@<%= review.author.username %></strong>
          <p class="starability-result m-0" data-rating="<%= review.rating %>"></p>
        </div>

        <p class="mt-2 mb-2"><%= review.comment %></p>

        <% if(currUser && review.author._id.equals(currUser._id)){ %>
        <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post">
          <button class="btn btn-sm btn-outline-danger">Delete</button>
        </form>
        <% } %>

      </div>
      <% } %>

    </div>

  </div>
</div>
</div>    
