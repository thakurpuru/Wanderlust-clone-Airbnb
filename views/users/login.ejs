<% layout("./layouts/boilerplate") %> 

<div class="signup-wrapper d-flex justify-content-center align-items-center min-vh-100">
  <div class="signup-card col-12 col-md-8 col-lg-5">

    <h2 class="text-center mb-3">Welcome Back</h2>

    <form action="/user/login" method="post" novalidate class="needs-validation">
      
      <div class="form-group mb-3">
        <label>Username</label>
        <input type="text" class="form-control" placeholder="Enter username" name="username" required>
        <div class="invalid-feedback">
          Please enter a valid username.
        </div>
      </div>

      <div class="form-group mb-3">
        <label>Password</label>
        <input type="password" class="form-control" placeholder="Enter password" name="password" required>
        <div class="invalid-feedback">
          Please enter correct password.
        </div>
      </div>

      <button type="submit" class="btn btn-dark w-100 mt-2">
        Login
      </button>
    </form>

    <!-- Optional -->
    <p class="text-center mt-3 mb-0 small">
      Don’t have an account? <a href="/user/signup">Sign up</a>
    </p>

  </div>
</div>